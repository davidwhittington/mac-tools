#!/usr/bin/env bash
# chromium-browse — wrapper for chromium-browse.py
# Ensures Python dependencies are available, then delegates to the Python script.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PYTHON="${CHROMIUM_BROWSE_PYTHON:-python3}"
PY_SCRIPT="${SCRIPT_DIR}/chromium-browse.py"

# Verify python3 exists
if ! command -v "$PYTHON" &>/dev/null; then
    echo "Error: python3 not found. Install Python 3.10+ first." >&2
    exit 1
fi

# Check minimum Python version (3.10 for union type syntax)
PY_VERSION=$("$PYTHON" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
PY_MAJOR=$("$PYTHON" -c "import sys; print(sys.version_info.major)")
PY_MINOR=$("$PYTHON" -c "import sys; print(sys.version_info.minor)")
if [ "$PY_MAJOR" -lt 3 ] || { [ "$PY_MAJOR" -eq 3 ] && [ "$PY_MINOR" -lt 10 ]; }; then
    echo "Error: Python 3.10+ required (found $PY_VERSION)" >&2
    exit 1
fi

# Auto-install missing pip dependencies into user site-packages
for pkg in websockets aiohttp; do
    if ! "$PYTHON" -c "import $pkg" &>/dev/null; then
        echo "Installing missing dependency: $pkg" >&2
        "$PYTHON" -m pip install --quiet --user "$pkg" || {
            echo "Error: Failed to install $pkg. Run: pip3 install websockets aiohttp" >&2
            exit 1
        }
    fi
done

exec "$PYTHON" "$PY_SCRIPT" "$@"
